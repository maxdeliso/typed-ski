common --enable_platform_specific_config
common --action_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1
common --repo_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1

# Retry external repository downloads (npm packages, LLVM tarballs, Node
# toolchain, etc.) on transient HTTP errors. CI cold-cache runs have
# occasionally hit 502s from upstream mirrors.
common --experimental_repository_downloader_retries=3
common --http_timeout_scaling=2.0

build --action_env=PATH
test --test_timeout=240
test --test_env=PATH
test:linux --test_env=HOME
test:macos --test_env=HOME
test:windows --enable_runfiles
test:windows --test_env=APPDATA
test:windows --test_env=LOCALAPPDATA
test:windows --test_env=TEMP
test:windows --test_env=TMP
test:windows --test_env=USERPROFILE
build:windows --action_env=APPDATA
build:windows --action_env=LOCALAPPDATA
build:windows --action_env=TEMP
build:windows --action_env=TMP

# --- PARALLEL AGENT DEVELOPMENT CONFIGURATION ---

# Shared Disk Cache: Share compiled build/test actions across all Git worktrees and agents.
# Placing it in the user home directory (~ expands to %USERPROFILE% on Windows, $HOME on Unix)
# ensures it persists across worktree deletions and git cleans.
build --disk_cache=~/bazel_cache

# Protect the shared cache from corruption during concurrent modifications by parallel agents.
build --guard_against_concurrent_changes

# Explicitly share repository downloads (npm packages, LLVM tarballs, etc.)
common --repository_cache=~/bazel_repo_cache

# Dynamic Resource Limits: Tweak limits to avoid premature CPU throttling
build --local_resources=cpu=HOST_CPUS*1.0
build --local_resources=memory=HOST_RAM*0.9


