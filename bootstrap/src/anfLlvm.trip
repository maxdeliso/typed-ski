poly emitDivU8 =
  \env : List (((List U8), (List U8))) =>
    \counter : Bin =>
      \instrs : List (List U8) =>
        \arg1 : AnfExpr =>
          \arg2 : AnfExpr =>
            do [Result (List U8) EmitRes] {
              op1 <- (atomOperand env arg1)
              op2 <- (atomOperand env arg2)
              dest = append [U8]
              "%__ll" (binToDigits counter)
              counter1 = incBin counter
              t1 = append [U8]
              "  "
                (
                  append
                    [U8]
                    dest
                    (
                      append
                        [U8]
                        "_t1 = trunc i64 "
                        (append [U8] op1 " to i8\n")
                    )
                )
              t2 = append [U8]
              "  "
                (
                  append
                    [U8]
                    dest
                    (
                      append
                        [U8]
                        "_t2 = trunc i64 "
                        (append [U8] op2 " to i8\n")
                    )
                )
              zero = append [U8]
              "  "
                (
                  append
                    [U8]
                    dest
                    (
                      append
                        [U8]
                        "_zero = icmp eq i8 "
                        (append [U8] dest "_t2, 0\n")
                    )
                )
              safe = append [U8]
              "  "
                (
                  append
                    [U8]
                    dest
                    (
                      append
                        [U8]
                        "_safe = select i1 "
                        (
                          append
                            [U8]
                            dest
                            (
                              append
                                [U8]
                                "_zero, i8 1, i8 "
                                (append [U8] dest "_t2\n")
                            )
                        )
                    )
                )
              raw = append [U8]
              "  "
                (
                  append
                    [U8]
                    dest
                    (
                      append
                        [U8]
                        "_raw = udiv i8 "
                        (
                          append
                            [U8]
                            dest
                            (append [U8] "_t1, " (append [U8] dest "_safe\n"))
                        )
                    )
                )
              res = append [U8]
              "  "
                (
                  append
                    [U8]
                    dest
                    (
                      append
                        [U8]
                        "_res = select i1 "
                        (
                          append
                            [U8]
                            dest
                            (
                              append
                                [U8]
                                "_zero, i8 0, i8 "
                                (append [U8] dest "_raw\n")
                            )
                        )
                    )
                )
              ext = append [U8] "  " (append [U8] dest (append [U8] " = zext i8 " (append [U8] dest (append [U8] "_res to i64\n"))))
              return
                Ok
                [List U8]
                [EmitRes]
                (
                  MkEmitRes
                    counter1
                    (
                      cons
                        [List U8]
                        ext
                        (
                          cons
                            [List U8]
                            res
                            (
                              cons
                                [List U8]
                                raw
                                (
                                  cons
                                    [List U8]
                                    safe
                                    (
                                      cons
                                        [List U8]
                                        zero
                                        (
                                          cons
                                            [List U8]
                                            t2
                                            (cons [List U8] t1 instrs)
                                        )
                                    )
                                )
                            )
                        )
                    )
                    dest
                )
            }

