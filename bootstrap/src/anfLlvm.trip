data EmitRes =
  | MkEmitRes Bin (List (List U8)) (List U8)

poly rec lookupEnv =
  \env : List (((List U8), (List U8))) =>
    \name : List U8 =>
      matchList
        [((List U8), (List U8))]
        [Maybe (List U8)]
        env
        (None [List U8])
        (
          \h : ((List U8), (List U8)) =>
            \t : List (((List U8), (List U8))) =>
              if [Maybe (List U8)] (eqListU8 (fst [List U8] [List U8] h) name)
                (\u : U8 => Some [List U8] (snd [List U8] [List U8] h))
                (\u : U8 => lookupEnv t name)
        )

poly atomOperand =
  \env : List (((List U8), (List U8))) =>
    \e : AnfExpr =>
      match e [Result (List U8) (List U8)] {
        | AE_Var n =>
          match (lookupEnv env n) [Result (List U8) (List U8)] {
            | None =>
              Err [List U8] [List U8] (append [U8] "Unbound variable: " n)
            | Some op => Ok [List U8] [List U8] op
          }
        | AE_Native t =>
          match t [Result (List U8) (List U8)] {
            | T_Byte b => Ok [List U8] [List U8] (u8ToDigits b)
            | T_S =>
              Err [List U8] [List U8] "Unsupported atomic expression"
            | T_K =>
              Err [List U8] [List U8] "Unsupported atomic expression"
            | T_I =>
              Err [List U8] [List U8] "Unsupported atomic expression"
            | T_B =>
              Err [List U8] [List U8] "Unsupported atomic expression"
            | T_C =>
              Err [List U8] [List U8] "Unsupported atomic expression"
            | T_SPrime =>
              Err [List U8] [List U8] "Unsupported atomic expression"
            | T_BPrime =>
              Err [List U8] [List U8] "Unsupported atomic expression"
            | T_CPrime =>
              Err [List U8] [List U8] "Unsupported atomic expression"
            | T_WriteOne =>
              Err [List U8] [List U8] "Unsupported atomic expression"
            | T_ReadOne =>
              Err [List U8] [List U8] "Unsupported atomic expression"
            | T_EqU8 =>
              Err [List U8] [List U8] "Unsupported atomic expression"
            | T_LtU8 =>
              Err [List U8] [List U8] "Unsupported atomic expression"
            | T_DivU8 =>
              Err [List U8] [List U8] "Unsupported atomic expression"
            | T_ModU8 =>
              Err [List U8] [List U8] "Unsupported atomic expression"
            | T_AddU8 =>
              Err [List U8] [List U8] "Unsupported atomic expression"
            | T_SubU8 =>
              Err [List U8] [List U8] "Unsupported atomic expression"
          }
        | AE_Lam n b => Err [List U8] [List U8] "Unsupported atom: lambda"
        | AE_Call f args => Err [List U8] [List U8] "Unsupported atom: call"
        | AE_Con tag total arity args =>
          Err [List U8] [List U8] "Unsupported atom: constructor"
        | AE_Case scrut arms => Err [List U8] [List U8] "Unsupported atom: case"
        | AE_Let name val body => Err [List U8] [List U8] "Unsupported atom: let"
      }

poly rec emitArgsString =
  \env : List (((List U8), (List U8))) =>
    \args : List AnfExpr =>
      \leading : Bool =>
        matchList
          [AnfExpr]
          [Result (List U8) (List U8)]
          args
          (Ok [List U8] [List U8] "")
          (
            \h : AnfExpr =>
              \t : List AnfExpr =>
                do [Result (List U8) (List U8)] {
                  op <- (atomOperand env h)
                  piece =
                  if [List U8] leading
                    (\u : U8 => append [U8] "i64 %" op)
                    (\u : U8 => append [U8] ", i64 %" op)
                  rest <- (emitArgsString env t false)
                  return Ok [List U8] [List U8] (append [U8] piece rest)
                }
          )

poly rec peelBinders =
  \e : AnfExpr =>
    \acc : List (List U8) =>
      match e [((List (List U8)), AnfExpr)] {
        | AE_Lam name body =>
          peelBinders body (append [List U8] acc ({List U8 | name}))
        | AE_Var name => {List (List U8), AnfExpr | acc, e}
        | AE_Native term => {List (List U8), AnfExpr | acc, e}
        | AE_Call name args => {List (List U8), AnfExpr | acc, e}
        | AE_Con tag total arity args => {List (List U8), AnfExpr | acc, e}
        | AE_Case scrut arms => {List (List U8), AnfExpr | acc, e}
        | AE_Let name val body => {List (List U8), AnfExpr | acc, e}
      }

poly rec emitCaseFieldBinds =
  \env : List (((List U8), (List U8))) =>
    \instrs : List (List U8) =>
      \scrutPtr : List U8 =>
        \params : List (List U8) =>
          \fieldIdx : U8 =>
            matchList
              [List U8]
              [((List (((List U8), (List U8))), List (List U8)))]
              params
              ({List (((List U8), (List U8))), List (List U8) | env, instrs})
              (
                \p : List U8 =>
                  \t : List (List U8) =>
                    let fldVar = append [U8] scrutPtr (append [U8] "_fld_" (u8ToDigits fieldIdx)) in
                    let line = append [U8] "  " (append [U8] fldVar (append [U8] " = call i64 @trip_obj_field(ptr " (append [U8] scrutPtr (append [U8] ", i64 " (append [U8] (u8ToDigits fieldIdx) ")\n"))))) in
                    emitCaseFieldBinds
                      (
                        cons
                          [((List U8), (List U8))]
                          ({List U8, List U8 | p, fldVar})
                          env
                      )
                      (cons [List U8] line instrs)
                      scrutPtr
                      t
                      (addU8 fieldIdx #u8(1))
              )

poly rec emitCtorFields =
  \env : List (((List U8), (List U8))) =>
    \counter : Bin =>
      \instrs : List (List U8) =>
        \objDest : List U8 =>
          \arity : U8 =>
            \args : List AnfExpr =>
              \idx : U8 =>
                matchList
                  [AnfExpr]
                  [Result (List U8) EmitRes]
                  args
                  (Ok [List U8] [EmitRes] (MkEmitRes counter instrs objDest))
                  (
                    \arg : AnfExpr =>
                      \t : List AnfExpr =>
                        match (atomOperand env arg) [Result (List U8) EmitRes] {
                          | Err e => Err [List U8] [EmitRes] e
                          | Ok op =>
                            let obj_ptr = append [U8] objDest "_p" in
                            let line = append [U8] "  call void @trip_obj_set_field(ptr " (append [U8] obj_ptr (append [U8] ", i64 " (append [U8] (u8ToDigits idx) (append [U8] ", i64 " (append [U8] op ")\n"))))) in
                            emitCtorFields
                              env
                              counter
                              (cons [List U8] line instrs)
                              objDest
                              arity
                              t
                              (addU8 idx #u8(1))
                        }
                  )

poly emitAddU8 =
  \env : List (((List U8), (List U8))) =>
    \counter : Bin =>
      \instrs : List (List U8) =>
        \arg1 : AnfExpr =>
          \arg2 : AnfExpr =>
            do [Result (List U8) EmitRes] {
              op1 <- (atomOperand env arg1)
              op2 <- (atomOperand env arg2)
              dest = append [U8]
              "%__ll" (binToDigits counter)
              counter1 = incBin counter
              t1 = append [U8]
              "  "
                (
                  append
                    [U8]
                    dest
                    (
                      append
                        [U8]
                        "_t1 = trunc i64 "
                        (append [U8] op1 " to i8\n")
                    )
                )
              t2 = append [U8]
              "  "
                (
                  append
                    [U8]
                    dest
                    (
                      append
                        [U8]
                        "_t2 = trunc i64 "
                        (append [U8] op2 " to i8\n")
                    )
                )
              res = append [U8]
              "  "
                (
                  append
                    [U8]
                    dest
                    (
                      append
                        [U8]
                        "_res = add i8 "
                        (
                          append
                            [U8]
                            dest
                            (append [U8] "_t1, " (append [U8] dest "_t2\n"))
                        )
                    )
                )
              ext = append [U8] "  " (append [U8] dest (append [U8] " = zext i8 " (append [U8] dest (append [U8] "_res to i64\n"))))
              return
                Ok
                [List U8]
                [EmitRes]
                (
                  MkEmitRes
                    counter1
                    (
                      cons
                        [List U8]
                        ext
                        (
                          cons
                            [List U8]
                            res
                            (cons [List U8] t2 (cons [List U8] t1 instrs))
                        )
                    )
                    dest
                )
            }

