import Prelude divU8
import Prelude modU8
import Prelude U8
import Prelude and
import Prelude or
import Prelude not
import Prelude Maybe
import Prelude Some
import Prelude None
import Prelude fst
import Prelude snd
import Prelude eqU8
import Prelude ltU8
import Nat Nat
