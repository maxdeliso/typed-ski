data Token =
  | T_LParen
  | T_RParen
  | T_LBrace
  | T_RBrace
  | T_LBracket
  | T_RBracket
  | T_Backslash
  | T_Arrow
  | T_FatArrow
  | T_Eq
  | T_Colon
  | T_Hash
  | T_Pipe
  | T_Dot
  | T_Comma
  | T_KwPoly
  | T_KwRec
  | T_KwLet
  | T_KwIn
  | T_KwMatch
  | T_KwModule
  | T_KwImport
  | T_KwExport
  | T_KwTyped
  | T_KwUntyped
  | T_KwCombinator
  | T_KwType
  | T_KwData
  | T_Ident (List U8)
  | T_Nat Bin
  | T_EOF

poly tokenTag = \tok : Token =>
  match tok [U8] {
    | T_LParen => 1
    | T_RParen => 2
    | T_LBrace => 3
    | T_RBrace => 4
    | T_LBracket => 5
    | T_RBracket => 6
    | T_Backslash => 7
    | T_Arrow => 8
    | T_FatArrow => 9
    | T_Eq => 10
    | T_Colon => 11
    | T_Hash => 12
    | T_Pipe => 13
    | T_Dot => 14
    | T_Comma => 15
    | T_KwPoly => 16
    | T_KwRec => 17
    | T_KwLet => 18
    | T_KwIn => 19
    | T_KwMatch => 20
    | T_KwModule => 21
    | T_KwImport => 22
    | T_KwExport => 23
    | T_KwTyped => 24
    | T_KwUntyped => 25
    | T_KwCombinator => 26
    | T_KwType => 27
    | T_KwData => 28
    | T_Ident str => 29
    | T_Nat n => 30
    | T_EOF => 31
  }


poly tokenText = \tok : Token =>
  match tok [List U8] {
    | T_LParen => nil [U8]
    | T_RParen => nil [U8]
    | T_LBrace => nil [U8]
    | T_RBrace => nil [U8]
    | T_LBracket => nil [U8]
    | T_RBracket => nil [U8]
    | T_Backslash => nil [U8]
    | T_Arrow => nil [U8]
    | T_FatArrow => nil [U8]
    | T_Eq => nil [U8]
    | T_Colon => nil [U8]
    | T_Hash => nil [U8]
    | T_Pipe => nil [U8]
    | T_Dot => nil [U8]
    | T_Comma => nil [U8]
    | T_KwPoly => "poly"
    | T_KwRec => "rec"
    | T_KwLet => "let"
    | T_KwIn => "in"
    | T_KwMatch => "match"
    | T_KwModule => "module"
    | T_KwImport => "import"
    | T_KwExport => "export"
    | T_KwTyped => "typed"
    | T_KwUntyped => "untyped"
    | T_KwCombinator => "combinator"
    | T_KwType => "type"
    | T_KwData => "data"
    | T_Ident str => str
    | T_Nat n => nil [U8]
    | T_EOF => nil [U8]
  }

poly tokenNatValue = \tok : Token =>
  match tok [U8] {
    | T_LParen => 0
    | T_RParen => 0
    | T_LBrace => 0
    | T_RBrace => 0
    | T_LBracket => 0
    | T_RBracket => 0
    | T_Backslash => 0
    | T_Arrow => 0
    | T_FatArrow => 0
    | T_Eq => 0
    | T_Colon => 0
    | T_Hash => 0
    | T_Pipe => 0
    | T_Dot => 0
    | T_Comma => 0
    | T_KwPoly => 0
    | T_KwRec => 0
    | T_KwLet => 0
    | T_KwIn => 0
    | T_KwMatch => 0
    | T_KwModule => 0
    | T_KwImport => 0
    | T_KwExport => 0
    | T_KwTyped => 0
    | T_KwUntyped => 0
    | T_KwCombinator => 0
    | T_KwType => 0
    | T_KwData => 0
    | T_Ident str => 0
    | T_Nat n => n
    | T_EOF => 0
  }

poly u8_space    : U8 = ' '
poly u8_newline  : U8 = '\n'
poly u8_cr       : U8 = '\r'
poly u8_tab      : U8 = '\t'
poly u8_underscore : U8 = '_'

poly u8_0 : U8 = '0'
poly u8_1 : U8 = '1'
