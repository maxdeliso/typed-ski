poly u8_y : U8 = 'y'
poly u8_z : U8 = 'z'

poly u8_A : U8 = 'A'
poly u8_B : U8 = 'B'
poly u8_C : U8 = 'C'
poly u8_D : U8 = 'D'
poly u8_E : U8 = 'E'
