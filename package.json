{
  "name": "@maxdeliso/typed-ski",
  "version": "0.17.1",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./lib/index.ts",
    "./bin/tripc": "./bin/tripc.ts"
  },
  "files": [
    "README.md",
    "SECURITY.md",
    "lib/**/*",
    "bin/**/*",
    "dist/**/*",
    "wasm/release.wasm"
  ],
  "jsr": {
    "publish": {
      "include": [
        "README.md",
        "SECURITY.md",
        "lib/**/*",
        "bin/**/*",
        "dist/**/*",
        "wasm/release.wasm"
      ]
    }
  },
  "engines": {
    "node": "25.x"
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  },
  "scripts": {
    "tripc": "node --experimental-transform-types bin/tripc.ts",
    "bundle:tripc": "esbuild bin/tripc.ts --bundle --outfile=dist/tripc.js --format=esm --platform=node",
    "bundle:tripc:minified": "esbuild bin/tripc.ts --bundle --minify --outfile=dist/tripc.min.js --format=esm --platform=node",
    "bundle:tripc:node": "esbuild bin/tripc.ts --bundle --outfile=dist/tripc.node.js --format=esm --platform=node",
    "dist": "mkdir -p dist && npm run bundle:tripc && npm run bundle:tripc:minified && npm run bundle:tripc:node",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-transform-types scripts/bazel.ts test"
  },
  "dependencies": {
    "random-seed": "0.3.0",
    "ts-morph": "^25.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@types/random-seed": "^0.3.5",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.0"
  }
}
