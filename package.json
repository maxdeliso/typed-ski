{
  "name": "@maxdeliso/typed-ski",
  "version": "0.18.4",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./lib/index.ts",
    "./bin/tripc": "./bin/tripc.ts"
  },
  "files": [
    "README.md",
    "SECURITY.md",
    "lib/**/*",
    "bin/**/*",
    "dist/**/*"
  ],
  "jsr": {
    "publish": {
      "include": [
        "README.md",
        "SECURITY.md",
        "lib/**",
        "bin/**",
        "dist/**"
      ],
      "exclude": [
        "!lib/**/*.generated.ts"
      ]
    }
  },
  "engines": {
    "node": "25.x"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "tripc": "node --disable-warning=ExperimentalWarning --experimental-transform-types bin/tripc.ts",
    "bench:avl": "node --disable-warning=ExperimentalWarning --experimental-transform-types test/avlBenchmark.ts",
    "dist": "node --disable-warning=ExperimentalWarning --experimental-transform-types scripts/bazel.ts dist",
    "typecheck": "tsc --noEmit",
    "test": "node --disable-warning=ExperimentalWarning --experimental-transform-types scripts/bazel.ts test"
  },
  "dependencies": {
    "random-seed": "0.3.0",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/random-seed": "^0.3.5",
    "esbuild": "^0.28.0",
    "json-stringify-safe": "5.0.1",
    "pnpm": "10.33.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
