{
  "name": "@maxdeliso/typed-ski",
  "version": "0.17.11",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./lib/index.ts",
    "./bin/tripc": "./bin/tripc.ts"
  },
  "files": [
    "README.md",
    "SECURITY.md",
    "lib/**/*",
    "bin/**/*",
    "dist/**/*",
    "wasm/release.wasm"
  ],
  "jsr": {
    "publish": {
      "include": [
        "README.md",
        "SECURITY.md",
        "lib/**",
        "bin/**",
        "dist/**",
        "wasm/release.wasm"
      ],
      "exclude": [
        "!lib/**/*.generated.ts",
        "!lib/evaluator/arenaHeader.generated.ts"
      ]
    }
  },
  "engines": {
    "node": "25.x"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "tripc": "node --disable-warning=ExperimentalWarning --experimental-transform-types bin/tripc.ts",
    "bench:avl": "node --disable-warning=ExperimentalWarning --experimental-transform-types test/avlBenchmark.ts",
    "bundle:tripc": "esbuild bin/tripc.ts --bundle --outfile=dist/tripc.js --format=esm --platform=node",
    "bundle:tripc:minified": "esbuild bin/tripc.ts --bundle --minify --outfile=dist/tripc.min.js --format=esm --platform=node",
    "bundle:tripc:node": "esbuild bin/tripc.ts --bundle --outfile=dist/tripc.node.js --format=esm --platform=node",
    "dist": "mkdir -p dist && npm run bundle:tripc && npm run bundle:tripc:minified && npm run bundle:tripc:node",
    "typecheck": "tsc --noEmit",
    "test": "node --disable-warning=ExperimentalWarning --experimental-transform-types scripts/bazel.ts test"
  },
  "dependencies": {
    "random-seed": "0.3.0",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/random-seed": "^0.3.5",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
