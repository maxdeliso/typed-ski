{
  "name": "@maxdeliso/typed-ski",
  "version": "0.20.1",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./lib/index.ts",
    "./bin/tripc": "./bin/tripc.ts"
  },
  "files": [
    "README.md",
    "SECURITY.md",
    "lib/**/*",
    "bin/**/*",
    "dist/**/*"
  ],
  "jsr": {
    "publish": {
      "include": [
        "README.md",
        "SECURITY.md",
        "lib/**",
        "bin/**",
        "dist/**"
      ],
      "exclude": [
        "!lib/**/*.generated.ts"
      ]
    }
  },
  "engines": {
    "node": "26.x"
  },
  "packageManager": "pnpm@11.1.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "prebuild": "node scripts/generate_version.mjs --ts-out lib/shared/version.generated.ts --jsr-json jsr.json",
    "build": "tsc --project tsconfig.emit.json",
    "tripc": "node ts_out/bin/tripc.js",
    "bench:avl": "node ts_out/test/avlBenchmark.js",
    "dist": "pnpm run build && node scripts/build_dist.mjs",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run build && node --test --test-global-setup ts_out/test/globalSetup.js --experimental-test-module-mocks 'ts_out/**/*.test.js'",
    "test:coverage": "pnpm run build && node --test --test-global-setup ts_out/test/globalSetup.js --experimental-test-module-mocks --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage.lcov 'ts_out/**/*.test.js'",
    "fmt:check": "prettier --check .",
    "fmt:fix": "prettier --write ."
  },
  "dependencies": {
    "random-seed": "0.3.0",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/random-seed": "^0.3.5",
    "esbuild": "^0.28.0",
    "json-stringify-safe": "5.0.1",
    "pnpm": "11.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
