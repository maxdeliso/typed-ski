module Test

import Prelude Bool
import Prelude true
import Prelude false
import Prelude if
import Prelude Bin
import Prelude eqBin
import Prelude List
import Prelude matchList
import Prelude Result
import Prelude Ok
import Prelude Err
import Lexer tokenizeBin
import Lexer Token
import Lexer tokenTag
import Lexer tokenText
import Lexer T_KwPoly
import Lexer T_Ident
import Lexer eqListFast

export main

poly isIdentAbcToken = \tok : Token =>
  if [Bool] (eqBin (tokenTag tok) (tokenTag (T_Ident "x")))
    (\u : Bin => eqListFast (tokenText tok) "abc")
    (\u : Bin => false)

poly isKeywordPolyToken = \tok : Token =>
  eqBin (tokenTag tok) (tokenTag T_KwPoly)

poly main =
  let testIdent =
    match (tokenizeBin "abc") [Bool] {
      | Err e => false
      | Ok toks =>
          matchList [Token] [Bool] toks false
            (\h : Token => \t : List Token => isIdentAbcToken h)
    }
  in
  let testKeyword =
    match (tokenizeBin "poly") [Bool] {
      | Err e => false
      | Ok toks =>
          matchList [Token] [Bool] toks false
            (\h : Token => \t : List Token => isKeywordPolyToken h)
    }
  in
  if [Bool] testIdent
    (\u : Bin => testKeyword)
    (\u : Bin => false)
