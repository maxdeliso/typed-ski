module Test

import Prelude Bool
import Prelude true
import Prelude false
import Prelude if
import Prelude Bin
import Prelude List
import Prelude nil
import Prelude cons
import Prelude U8
import Prelude matchList
import Prelude Result
import Prelude Ok
import Prelude Err
import Lexer Token
import Lexer T_KwRec
import Lexer T_KwPoly
import Lexer T_KwCombinator
import Lexer T_KwUntyped
import Lexer T_KwTyped
import Lexer T_KwModule
import Lexer T_Ident
import Lexer T_Eq
import Lexer T_Colon
import Lexer T_Nat
import Lexer T_Backslash
import Lexer T_FatArrow
import Lexer T_Comma
import Lexer T_Dot
import Lexer T_EOF
import Lexer eqListU8
import Parser parseProgram
import Parser DefKind
import Parser K_Poly
import Parser K_Typed
import Parser K_Untyped
import Parser K_Combinator
import Parser Decl
import Parser D_Module
import Parser D_Import
import Parser D_Export
import Parser D_Type
import Parser D_Data
import Parser D_Def

export main

poly eqDefKind = \a : DefKind => \b : DefKind =>
  match a [Bool] {
    | K_Poly =>
      match b [Bool] {
        | K_Poly => true
        | K_Typed => false
        | K_Untyped => false
        | K_Combinator => false
      }
    | K_Typed =>
      match b [Bool] {
        | K_Poly => false
        | K_Typed => true
        | K_Untyped => false
        | K_Combinator => false
      }
    | K_Untyped =>
      match b [Bool] {
        | K_Poly => false
        | K_Typed => false
        | K_Untyped => true
        | K_Combinator => false
      }
    | K_Combinator =>
      match b [Bool] {
        | K_Poly => false
        | K_Typed => false
        | K_Untyped => false
        | K_Combinator => true
      }
  }

poly main =
  let t0 = nil [Token] in
  let t1 = cons [Token] T_EOF t0 in
  let t2 = cons [Token] T_Dot t1 in
  let t3 = cons [Token] T_Comma t2 in
  let t4 = cons [Token] T_Eq t3 in
  let t5 = cons [Token] (T_Ident "c") t4 in
  let t6 = cons [Token] T_KwCombinator t5 in
  let t7 = cons [Token] (T_Ident "x") t6 in
  let t8 = cons [Token] T_FatArrow t7 in
  let t9 = cons [Token] (T_Ident "x") t8 in
  let t10 = cons [Token] T_Backslash t9 in
  let t11 = cons [Token] T_Eq t10 in
  let t12 = cons [Token] (T_Ident "u") t11 in
  let t13 = cons [Token] T_KwUntyped t12 in
  let t14 = cons [Token] (T_Nat "1") t13 in
  let t15 = cons [Token] T_Eq t14 in
  let t16 = cons [Token] (T_Ident "Nat") t15 in
  let t17 = cons [Token] T_Colon t16 in
  let t18 = cons [Token] (T_Ident "t") t17 in
  let t19 = cons [Token] T_KwTyped t18 in
  let t20 = cons [Token] (T_Ident "id") t19 in
  let t21 = cons [Token] T_Eq t20 in
  let t22 = cons [Token] (T_Ident "p") t21 in
  let t23 = cons [Token] T_KwRec t22 in
  let t24 = cons [Token] T_KwPoly t23 in
  let t25 = cons [Token] (T_Ident "M") t24 in
  let input = cons [Token] T_KwModule t25 in
  match (parseProgram input) [Bool] {
    | Err e => false
    | Ok decls =>
      matchList [Decl] [Bool] decls false
        (\d0 : Decl => \rest0 : List Decl =>
          match d0 [Bool] {
            | D_Module modName =>
              if [Bool] (eqListU8 modName "M")
                (\u : U8 =>
                  matchList [Decl] [Bool] rest0 false
                    (\d1 : Decl => \rest1 : List Decl =>
                      match d1 [Bool] {
                        | D_Module name => false
                        | D_Import m s => false
                        | D_Export x => false
                        | D_Type x => false
                        | D_Data x => false
                        | D_Def kind isRec name body =>
                          if [Bool] (eqDefKind kind K_Poly)
                            (\u : U8 =>
                              if [Bool] isRec
                                (\u : U8 =>
                                  if [Bool] (eqListU8 name "p")
                                    (\u : U8 =>
                                      matchList [Decl] [Bool] rest1 false
                                        (\d2 : Decl => \rest2 : List Decl =>
                                          match d2 [Bool] {
                                            | D_Module name => false
                                            | D_Import m s => false
                                            | D_Export x => false
                                            | D_Type x => false
                                            | D_Data x => false
                                            | D_Def kind2 isRec2 name2 body2 =>
                                              if [Bool] (eqDefKind kind2 K_Typed)
                                                (\u : U8 =>
                                                  if [Bool] isRec2
                                                    (\u : U8 => false)
                                                    (\u : U8 =>
                                                      if [Bool] (eqListU8 name2 "t")
                                                        (\u : U8 =>
                                                          matchList [Decl] [Bool] rest2 false
                                                            (\d3 : Decl => \rest3 : List Decl =>
                                                              match d3 [Bool] {
                                                                | D_Module name => false
                                                                | D_Import m s => false
                                                                | D_Export x => false
                                                                | D_Type x => false
                                                                | D_Data x => false
                                                                | D_Def kind3 isRec3 name3 body3 =>
                                                                  if [Bool] (eqDefKind kind3 K_Untyped)
                                                                    (\u : U8 =>
                                                                      if [Bool] isRec3
                                                                        (\u : U8 => false)
                                                                        (\u : U8 =>
                                                                          if [Bool] (eqListU8 name3 "u")
                                                                            (\u : U8 =>
                                                                              matchList [Decl] [Bool] rest3 false
                                                                                (\d4 : Decl => \rest4 : List Decl =>
                                                                                  match d4 [Bool] {
                                                                                    | D_Module name => false
                                                                                    | D_Import m s => false
                                                                                    | D_Export x => false
                                                                                    | D_Type x => false
                                                                                    | D_Data x => false
                                                                                    | D_Def kind4 isRec4 name4 body4 =>
                                                                                      if [Bool] (eqDefKind kind4 K_Combinator)
                                                                                        (\u : U8 =>
                                                                                          if [Bool] isRec4
                                                                                            (\u : U8 => false)
                                                                                            (\u : U8 =>
                                                                                              if [Bool] (eqListU8 name4 "c")
                                                                                                (\u : U8 =>
                                                                                                  matchList [Decl] [Bool] rest4 true
                                                                                                    (\d5 : Decl => \rest5 : List Decl => false))
                                                                                                (\u : U8 => false))
                                                                                        )
                                                                                        (\u : U8 => false)
                                                                                  })
                                                                            )
                                                                            (\u : U8 => false))
                                                                    )
                                                                    (\u : U8 => false)
                                                              })
                                                        )
                                                        (\u : U8 => false))
                                                )
                                                (\u : U8 => false)
                                          })
                                    )
                                    (\u : U8 => false))
                                (\u : U8 => false)
                            )
                            (\u : U8 => false)
                      })
                )
                (\u : U8 => false)
            | D_Import m s => false
            | D_Export x => false
            | D_Type x => false
            | D_Data x => false
            | D_Def kind isRec name body => false
          })
  }
