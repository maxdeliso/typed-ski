module Test

import Prelude Bool
import Prelude true
import Prelude false
import Prelude if
import Prelude Bin
import Prelude List
import Prelude nil
import Prelude cons
import Prelude U8
import Prelude matchList
import Prelude Result
import Prelude Ok
import Prelude Err
import Lexer Token
import Lexer T_KwRec
import Lexer T_KwPoly
import Lexer T_KwCombinator
import Lexer T_KwUntyped
import Lexer T_KwTyped
import Lexer T_KwData
import Lexer T_KwType
import Lexer T_KwExport
import Lexer T_KwImport
import Lexer T_KwModule
import Lexer T_Ident
import Lexer T_Eq
import Lexer T_Hash
import Lexer T_Arrow
import Lexer T_Nat
import Lexer T_Colon
import Lexer T_Backslash
import Lexer T_FatArrow
import Lexer T_Comma
import Lexer T_Dot
import Lexer T_EOF
import Lexer eqListU8
import Parser parseProgram
import Parser Decl
import Parser D_Module
import Parser D_Import
import Parser D_Export
import Parser D_Type
import Parser D_Data
import Parser D_Def

export main

poly main =
  let t0 = nil [Token] in
  let t1 = cons [Token] T_EOF t0 in
  let t2 = cons [Token] (T_Ident "id") t1 in
  let t3 = cons [Token] T_Eq t2 in
  let t4 = cons [Token] (T_Ident "main") t3 in
  let t5 = cons [Token] T_KwRec t4 in
  let t6 = cons [Token] T_KwPoly t5 in
  let t7 = cons [Token] T_Dot t6 in
  let t8 = cons [Token] T_Comma t7 in
  let t9 = cons [Token] T_Eq t8 in
  let t10 = cons [Token] (T_Ident "io") t9 in
  let t11 = cons [Token] T_KwCombinator t10 in
  let t12 = cons [Token] (T_Ident "x") t11 in
  let t13 = cons [Token] T_FatArrow t12 in
  let t14 = cons [Token] (T_Ident "x") t13 in
  let t15 = cons [Token] T_Backslash t14 in
  let t16 = cons [Token] T_Eq t15 in
  let t17 = cons [Token] (T_Ident "u") t16 in
  let t18 = cons [Token] T_KwUntyped t17 in
  let t19 = cons [Token] (T_Nat "1") t18 in
  let t20 = cons [Token] T_Eq t19 in
  let t21 = cons [Token] (T_Ident "Nat") t20 in
  let t22 = cons [Token] T_Colon t21 in
  let t23 = cons [Token] (T_Ident "t") t22 in
  let t24 = cons [Token] T_KwTyped t23 in
  let t25 = cons [Token] (T_Ident "A") t24 in
  let t26 = cons [Token] (T_Ident "Some") t25 in
  let t27 = cons [Token] (T_Ident "None") t26 in
  let t28 = cons [Token] T_Eq t27 in
  let t29 = cons [Token] (T_Ident "A") t28 in
  let t30 = cons [Token] (T_Ident "Maybe") t29 in
  let t31 = cons [Token] T_KwData t30 in
  let t32 = cons [Token] (T_Ident "X") t31 in
  let t33 = cons [Token] T_Arrow t32 in
  let t34 = cons [Token] (T_Ident "X") t33 in
  let t35 = cons [Token] T_Hash t34 in
  let t36 = cons [Token] T_Eq t35 in
  let t37 = cons [Token] (T_Ident "Nat") t36 in
  let t38 = cons [Token] T_KwType t37 in
  let t39 = cons [Token] (T_Ident "main") t38 in
  let t40 = cons [Token] T_KwExport t39 in
  let t41 = cons [Token] (T_Ident "id") t40 in
  let t42 = cons [Token] (T_Ident "Prelude") t41 in
  let t43 = cons [Token] T_KwImport t42 in
  let t44 = cons [Token] (T_Ident "M") t43 in
  let input = cons [Token] T_KwModule t44 in
  match (parseProgram input) [Bool] {
    | Err e => false
    | Ok decls =>
      matchList [Decl] [Bool] decls false
        (\h : Decl => \t : List Decl =>
          match h [Bool] {
            | D_Module name => eqListU8 name "M"
            | D_Import m s => false
            | D_Export x => false
            | D_Type x => false
            | D_Data x => false
            | D_Def kind isRec x body => false
          })
  }
