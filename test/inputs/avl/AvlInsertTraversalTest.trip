module AvlInsertTraversalTest

import Nat Nat
import Nat zero
import Nat succ
import Nat add
import Nat mul
import Nat lte
import Nat fromBin
import Prelude Bin
import Prelude BZ
import Prelude B0
import Prelude B1
import Prelude List
import Prelude matchList
import Avl empty
import Avl insert
import Avl toListKeys

export main

poly tenBin : Bin = B0 (B1 (B0 (B1 BZ)))

poly rec encode = \keys : List Nat =>
  matchList [Nat] [Nat] keys zero
    (\h : Nat => \t : List Nat => add h (mul (encode t) (fromBin tenBin)))

poly main =
  let one = succ zero in
  let two = succ one in
  let three = succ two in
  let t0 = empty [Nat] [Nat] in
  let t1 = insert [Nat] [Nat] lte two two t0 in
  let t2 = insert [Nat] [Nat] lte one one t1 in
  let t3 = insert [Nat] [Nat] lte three three t2 in
  encode (toListKeys [Nat] [Nat] t3)
