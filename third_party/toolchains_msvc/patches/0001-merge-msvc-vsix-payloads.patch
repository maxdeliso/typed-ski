+def _run_or_fail(ctx, args, message):
+    result = ctx.execute(args, quiet = True)
+    if result.return_code == 0:
+        return
+
+    details = ""
+    if result.stdout:
+        details += "\nstdout:\n{}".format(result.stdout)
+    if result.stderr:
+        details += "\nstderr:\n{}".format(result.stderr)
+    fail("{} failed (exit {}){}".format(message, result.return_code, details))
+
+def _merge_msvc_payload_dir(ctx, merge_script, package_root, payload_dir, destination):
+    source = str(ctx.path("{}/Contents/VC/{}/MSVC".format(package_root, payload_dir))).replace("/", "\\")
+    destination = str(ctx.path(destination)).replace("/", "\\")
+    _run_or_fail(
+        ctx,
+        [
+            "powershell",
+            "-NoProfile",
+            "-ExecutionPolicy",
+            "Bypass",
+            "-File",
+            str(ctx.path(merge_script)).replace("/", "\\"),
+            "-Source",
+            source,
+            "-Destination",
+            destination,
+        ],
+        "Merging {} from {}".format(payload_dir, package_root),
+    )
+
+def _require_extracted_path(ctx, path):
+    if not ctx.path(path).exists:
+        fail("Expected MSVC payload path missing after extraction: {}".format(path))
+
